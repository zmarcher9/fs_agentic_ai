# Runtime
APP_ENV=development
HOST=0.0.0.0
PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,https://firesim.cs.gsu.edu

# LLM
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4
LLM_MAX_CONCURRENT_TURNS=4

# Geocoder: use mapbox in production; Nominatim is development-only.
GEOCODER_PROVIDER=nominatim
MAPBOX_ACCESS_TOKEN=
MAPBOX_PERMANENT=true
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=FireSim-AI/1.0 (+https://firesim.cs.gsu.edu/)
GEOCODER_TIMEOUT_SECONDS=10
GEOCODER_CACHE_TTL_SECONDS=3600
GEOCODER_CACHE_MAX_ENTRIES=500

# Browser
FIREMAP_URL=http://host.docker.internal:5173
PLAYWRIGHT_MAX_CONTEXTS=2
PLAYWRIGHT_MAX_WAITERS=8
PLAYWRIGHT_ACQUIRE_TIMEOUT_SECONDS=2
PLAYWRIGHT_IDLE_TTL_SECONDS=600

# Optional future simulator integration
FIRESIM_PATH=

# LLM provider credentials (set the one matching LLM_PROVIDER)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Which LLM backend to use: openai | anthropic
LLM_PROVIDER=openai

# Path to FireMapSim executable or base URL for its HTTP API
FIRESIM_PATH=/path/to/firemapsim

# Application environment: development | production
APP_ENV=development
